// Road to IT Olympics — full schema
// Implements §4 of handoff.md, plus the wall between practice and selection (§1).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  role          String   @default("student") // 'admin' | 'instructor' | 'student'
  nickname      String
  realName      String?
  studentId     String?
  avatarId      String   @default("avatar-01")
  createdAt     DateTime @default(now())

  captainOf           DomainCaptain[]
  submissions         Submission[]
  proctoredMocksFor   ProctoredMock[]  @relation("MockSubject")
  proctoredMocksBy    ProctoredMock[]  @relation("MockEnteredBy")
  mocksAsPartner      ProctoredMock[]  @relation("MockPartner")
  teamSelectionsFor   TeamSelection[]  @relation("TeamSelected")
  teamSelectionsBy    TeamSelection[]  @relation("TeamDecidedBy")
  milestonesCreated   Milestone[]      @relation("MilestoneCreator")
  spotlights          WeeklySpotlight[]
  evalsAsSubject      CandidateEvaluation[] @relation("EvalSubject")
  evalsAsPartner      CandidateEvaluation[] @relation("EvalPartner")
  evalsAsEvaluator    CandidateEvaluation[] @relation("EvalEvaluator")
}

model Domain {
  id            String   @id @default(cuid())
  key           String   @unique // 'java', 'web', 'db', 'quiz', 'python', 'net'
  name          String
  shortName     String   @default("")
  description   String?
  color         String   @default("#16a34a")
  icon          String   @default("Trophy")
  practiceNote  String   @default("")
  contestFormat String   @default("")
  pairBased     Boolean  @default(false)
  teamSize      Int      @default(1)

  captains               DomainCaptain[]
  milestones             Milestone[]
  proctoredMocks         ProctoredMock[]
  teamSelections         TeamSelection[]
  candidateEvaluations   CandidateEvaluation[]
}

model DomainCaptain {
  userId   String
  domainId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@id([userId, domainId])
}

model Milestone {
  id                 String   @id @default(cuid())
  domainId           String
  seasonId           String
  version            Int      @default(1)
  parentMilestoneId  String?  // links versions of "the same" milestone
  weekOrPhase        String   // 'july-diagnostic', 'aug-w1', 'sep-maint', 'oct-sprint', etc.
  mode               String   // 'tutor' | 'assessment' | 'journal'
  difficulty         String   // 'easy' | 'average' | 'difficult'
  title              String
  promptTemplate     String
  acceptedInputTypes String   @default("guided_form") // JSON array
  status             String   @default("draft") // 'draft' | 'active' | 'archived'
  isLocked           Boolean  @default(false)
  createdBy          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  domain      Domain       @relation(fields: [domainId], references: [id])
  season      Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  creator     User         @relation("MilestoneCreator", fields: [createdBy], references: [id])
  submissions Submission[]
}

model Submission {
  id                        String   @id @default(cuid())
  milestoneId               String
  milestoneVersion          Int      // pinned at submit time, not inferred via join
  userId                    String
  clientSubmissionTimestamp DateTime // device clock; drives the streak
  serverReceivedTimestamp   DateTime @default(now())
  syncStatus                String   @default("synced")
  inputType                 String   // 'guided_form' | 'json' | 'screenshot'
  aiShareLink               String?
  aiScore                   Int?
  confidence                Int?     // 1-5 self-reported
  weaknessTags              String   @default("[]") // JSON array
  reflection                String?  // free-form journal/reflection
  rawPayload                String   @default("{}") // JSON

  milestone Milestone @relation(fields: [milestoneId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model ProctoredMock {
  id            String   @id @default(cuid())
  domainId      String
  seasonId      String
  userId        String
  pairPartnerId String?
  score         Float
  enteredById   String
  eventDate     DateTime
  notes         String?

  domain     Domain @relation(fields: [domainId], references: [id])
  season     Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user       User   @relation("MockSubject", fields: [userId], references: [id])
  partner    User?  @relation("MockPartner", fields: [pairPartnerId], references: [id])
  enteredBy  User   @relation("MockEnteredBy", fields: [enteredById], references: [id])
}

model TeamSelection {
  id          String   @id @default(cuid())
  domainId    String
  seasonId    String
  userId      String
  decidedById String
  decidedAt   DateTime @default(now())
  rationale   String?

  domain    Domain @relation(fields: [domainId], references: [id])
  season    Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user      User   @relation("TeamSelected", fields: [userId], references: [id])
  decidedBy User   @relation("TeamDecidedBy", fields: [decidedById], references: [id])

  // One selection per (season, domain, student)
  @@unique([seasonId, domainId, userId])
}

model WeeklySpotlight {
  id        String   @id @default(cuid())
  userId    String
  seasonId  String
  weekOf    DateTime
  reason    String   // 'streak' | 'solve' | 'reflection'
  blurb     String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
}

// Staff-only candidate evaluations — from handoff_added.md.
// Never writes to TeamSelection automatically. Append-only.
// Students have NO read path to this table, not even their own row.
model CandidateEvaluation {
  id                String   @id @default(cuid())
  domainId          String
  seasonId          String
  userId            String                     // the student being evaluated
  pairedWithUserId  String?                    // for Java / Quiz Bee suggested pairings
  evaluatedBy       String                     // captain/instructor who ran it
  evaluationBasis   String   @default("practice_only")  // 'practice_only' | 'proctored_only' | 'combined'
  aiSummary         String                     // human-readable read, shown in the panel
  strengths         String   @default("[]")    // JSON array of strings
  weaknesses        String   @default("[]")    // JSON array of strings
  complementarity   String?                    // for pairs: how they complement each other
  roleAssignment    String?                    // for pairs: who does what (e.g. "A takes syntax-heavy, B takes edge-cases")
  recommendation    String?                    // freeform recommendation note
  rawPayload        String   @default("{}")    // JSON — full structured AI output, for audit
  createdAt         DateTime @default(now())

  domain       Domain @relation(fields: [domainId], references: [id])
  season       Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user         User   @relation("EvalSubject", fields: [userId], references: [id])
  pairedWith   User?  @relation("EvalPartner", fields: [pairedWithUserId], references: [id])
  evaluatedBy_ User   @relation("EvalEvaluator", fields: [evaluatedBy], references: [id])
}

model AppEvent {
  id        String   @id @default(cuid())
  kind      String   // 'milestone-published' | 'mock-graded' | 'team-selected' | 'spotlight'
  title     String
  detail    String?
  createdAt DateTime @default(now())
}

model SystemPromptTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  template    String
  mode        String   @default("tutor")
  createdAt   DateTime @default(now())
}

model Season {
  id        String    @id @default(cuid())
  name      String    @unique
  startDate DateTime
  endDate   DateTime
  status    String    @default("active")
  createdAt DateTime  @default(now())

  phases           SeasonPhase[]
  milestones       Milestone[]
  proctoredMocks   ProctoredMock[]
  teamSelections   TeamSelection[]
  weeklySpotlights WeeklySpotlight[]
  candidateEvaluations CandidateEvaluation[]
}

model SeasonPhase {
  id          String   @id @default(cuid())
  seasonId    String
  key         String
  label       String
  shortLabel  String
  description String
  isMockHeavy Boolean  @default(false)
  sequence    Int

  season      Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, key])
}
