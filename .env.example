# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Prisma Database Connection URL
# For local development with SQLite, you can use:
# DATABASE_URL="file:./db/custom.db"
# For production docker compose container, use:
# DATABASE_URL="file:/app/db/custom.db"
DATABASE_URL="file:/app/db/custom.db"

# -----------------------------------------------------------------------------
# Authentication & Cookies
# -----------------------------------------------------------------------------
# Next.js Node environment (production or development)
NODE_ENV="production"

# HMAC secret key used to sign and verify session cookies.
# IMPORTANT: Provide a unique, random string of at least 32 characters in production.
# Example: run `openssl rand -base64 32` to generate one.
SESSION_SECRET="your-super-secret-random-key-at-least-32-chars-long"

# Set to "false" to disable the Secure flag on cookies for testing on a local IP
# address (e.g. http://192.168.1.100:3000) over plain, insecure HTTP.
# In actual production exposed to the internet with HTTPS, omit this or set to "true".
COOKIE_SECURE="false"

# -----------------------------------------------------------------------------
# Branding & App URL
# -----------------------------------------------------------------------------
# The public-facing URL of the application. 
# Used to generate links inside Discord webhook alerts.
# Defaults to "http://localhost:3000" if not set.
APP_PUBLIC_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Discord Webhook Integration
# -----------------------------------------------------------------------------
# Incoming webhook URL from Discord to receive channel notifications (downtime, milestones, leaderboard, etc.).
# Leave empty to disable Discord notifications.
DISCORD_WEBHOOK_URL=""

# -----------------------------------------------------------------------------
# Email Provider (Resend)
# -----------------------------------------------------------------------------
# API key for Resend email delivery. Required for sending magic links or verification emails.
RESEND_API_KEY=""

# The sender identity for outgoing emails. Must be a domain verified in Resend.
# Defaults to "Road to IT Olympics <onboarding@resend.dev>" if not set.
RESEND_FROM_EMAIL="Road to IT Olympics <onboarding@resend.dev>"

# -----------------------------------------------------------------------------
# Seeding / Initial Administrator Account
# -----------------------------------------------------------------------------
# To prevent leftover accounts on production, the seed script will ONLY create
# the initial administrator user if both ADMIN_EMAIL and ADMIN_PASSWORD are set.
# If these are left blank, the seed script will only seed system templates and domains.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_REALNAME=""
ADMIN_NICKNAME=""
