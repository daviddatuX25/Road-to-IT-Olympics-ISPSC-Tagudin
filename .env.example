# Database configuration (Defaults to local SQLite db/custom.db)
DATABASE_URL="file:./db/custom.db"

# Session cookie secret (Generate a 64-char hex string in prod: openssl rand -hex 32)
SESSION_SECRET="your-development-session-secret-here-at-least-32-chars"

# Public URL of the application (used for links, e.g., in Discord webhooks)
APP_PUBLIC_URL="http://localhost:3000"

# Admin credentials for auto-seeding/syncing on startup
ADMIN_EMAIL="admin@ito.test"
ADMIN_PASSWORD="olypmics2026"
ADMIN_REALNAME="Mara Santos"
ADMIN_NICKNAME="Capt. Mara"

# Optional Discord Webhook for system notifications / alerts
DISCORD_WEBHOOK_URL=""

# Optional Resend configuration for password recovery/emails
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Road to IT Olympics <onboarding@resend.dev>"

# Production environment configurations (often set automatically or via Dokploy UI)
NODE_ENV="development"
PORT=3000
HOSTNAME="localhost"
